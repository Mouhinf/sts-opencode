rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Lecture publique pour le contenu
    match /properties/{doc} {
      allow read: if true;
      allow write: if true;
    }
    
    match /vehicles/{doc} {
      allow read: if true;
      allow write: if true;
    }
    
    match /formations/{doc} {
      allow read: if true;
      allow write: if true;
    }
    
    match /blog/{doc} {
      allow read: if true;
      allow write: if true;
    }
    
    match /messages/{doc} {
      allow read, write: if true;
    }
    
    match /quotes/{doc} {
      allow read, write: if true;
    }
    
    match /reservations/{doc} {
      allow read, write: if true;
    }
    
    match /devis/{doc} {
      allow read, write: if true;
    }
    
    match /newsletter/{doc} {
      allow read, write: if true;
    }
    
    // Tout le reste - lecture seule
    match /{document=**} {
      allow read: if true;
    }
  }
}